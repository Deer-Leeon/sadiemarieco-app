# ──────────────────────────────────────────────────────────────
# Operating system files
# ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ──────────────────────────────────────────────────────────────
# Editor / IDE files
# ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.cursor/*
!.cursor/rules/
!.cursor/rules/**

# ──────────────────────────────────────────────────────────────
# Logs
# ──────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ──────────────────────────────────────────────────────────────
# Dependencies (in case you add tooling later)
# ──────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ──────────────────────────────────────────────────────────────
# Build output
# ──────────────────────────────────────────────────────────────
dist/
build/
.cache/

# ──────────────────────────────────────────────────────────────
# Next.js
# ──────────────────────────────────────────────────────────────
.next/
out/
next-env.d.ts
*.tsbuildinfo

# ──────────────────────────────────────────────────────────────
# Environment files (never commit secrets)
# ──────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ──────────────────────────────────────────────────────────────
# Vercel
# ──────────────────────────────────────────────────────────────
.vercel

# ──────────────────────────────────────────────────────────────
# Local backups (not for the repo)
# ──────────────────────────────────────────────────────────────
.image-originals/

# ──────────────────────────────────────────────────────────────
# Python venv (used only for local image processing scripts)
# ──────────────────────────────────────────────────────────────
.venv/
.env*.local
